{
  "name": "ai_solver_client",
  "version": "1.1.0",
  "main": "main.js",
  "description": "AI多模态智能审题工作台",
  "author": "AI Boss",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i tailwind.src.css -o tailwind.css --minify",
    "pack": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.aisolver.client",
    "productName": "AI智能审题工作台",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.5.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^3.4.19"
  }
}
